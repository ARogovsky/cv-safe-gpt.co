{
  "mcpServers": {
    "browser": {
      "command": "npx",
      "args": [
        "-y",
        "@executeautomation/playwright-mcp-server"
      ],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "disabled": true,
      "autoApprove": [
        "playwright_navigate",
        "playwright_screenshot"
      ]
    }
  }
}